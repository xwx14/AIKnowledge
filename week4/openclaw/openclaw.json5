{
  // OpenClaw Gateway 配置 — AI 知识库 V4 生产版
  // OpenClaw 是消息网关平台，统一接入多个 IM 渠道

  "gateway": {
    "port": 3000,
    "host": "0.0.0.0",
    "log_level": "info",

    // 渠道接入配置
    "channels": {
      "telegram": {
        "enabled": true,
        "token": "{env:TELEGRAM_BOT_TOKEN}",
        "webhook_path": "/webhook/telegram",
        "parse_mode": "MarkdownV2"
      },
      "feishu": {
        "enabled": true,
        "app_id": "{env:FEISHU_APP_ID}",
        "app_secret": "{env:FEISHU_APP_SECRET}",
        "verification_token": "{env:FEISHU_VERIFICATION_TOKEN}",
        "webhook_path": "/webhook/feishu"
      }
    }
  },

  // 消息路由绑定 — 按正则匹配分发到不同 Agent
  "bindings": [
    {
      "pattern": "知识|搜索|查询|search|find",
      "agent": "knowledge-query",
      "description": "知识库检索 Agent"
    },
    {
      "pattern": "简报|摘要|今日|daily|digest",
      "agent": "daily-briefing",
      "description": "每日简报生成 Agent"
    },
    {
      "pattern": "订阅|subscribe|取消订阅|unsubscribe",
      "agent": "subscription-manager",
      "description": "订阅管理 Agent"
    },
    {
      "pattern": "最高评分|最高分|top.rated|评分最高|best",
      "agent": "top-rated",
      "description": "按关键字搜索评分最高的项目"
    },
    {
      "pattern": "*",
      "agent": "general-chat",
      "description": "通用对话 Agent（兜底）"
    }
  ],

  // Agent 定义
  "agents": {
    "knowledge-query": {
      "soul": "./SOUL.md",
      "skill": "./skills/knowledge-query/SKILL.md",
      "timeout": 30000
    },
    "daily-briefing": {
      "soul": "./SOUL.md",
      "skill": "./skills/daily-digest/SKILL.md",
      "script": "../distribution/formatter.py",
      "timeout": 60000
    },
    "subscription-manager": {
      "soul": "./SOUL.md",
      "timeout": 10000
    },
    "top-rated": {
      "soul": "./SOUL.md",
      "skill": "./skills/top-rated/SKILL.md",
      "script": "./skills/top-rated/top-rated.py",
      "timeout": 15000
    },
    "general-chat": {
      "soul": "./SOUL.md",
      "timeout": 15000
    }
  },

  // 限流配置
  "rate_limit": {
    "per_user": 30,
    "per_minute": 100,
    "burst": 5
  }
}
