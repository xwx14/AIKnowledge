# Example .env file for AI Knowledge Base
# Copy .env.example to .env and fill in your actual keys

# ============================================================
# LLM Provider (pipeline analysis)
# ============================================================

# Select provider: deepseek, qwen, glm, or kimi (default: deepseek)
LLM_PROVIDER=deepseek

# API Keys for each provider (only the selected provider's key is required)
# - DeepSeek: https://platform.deepseek.com/api_keys
# - Qwen:     https://dashscope.console.aliyun.com/apiKey
# - Kimi:     https://platform.moonshot.cn/console/api-keys
# - GLM:      https://open.bigmodel.cn/usercenter/apikeys
DEEPSEEK_API_KEY=your_actual_deepseek_api_key_here
QWEN_API_KEY=your_actual_qwen_api_key_here
KIMI_API_KEY=your_actual_kimi_api_key_here
GLM_API_KEY=your_actual_glm_api_key_here

# ============================================================
# Telegram Bot (distribution/publisher)
# ============================================================

# Create a bot via @BotFather, get token from there
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Send /start to your bot, then visit the URL below to get chat_id
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ============================================================
# Feishu (Lark) Bot App (distribution/publisher)
# ============================================================

# Feishu Open Platform: https://open.feishu.cn/app
# Create an app, enable robot capability, get credentials below
FEISHU_APP_ID=your_feishu_app_id_here
FEISHU_APP_SECRET=your_feishu_app_secret_here

# Feishu webhook for receiving events (optional, for interactive cards)
FEISHU_VERIFICATION_TOKEN=your_feishu_verification_token_here

# Feishu chat ID to send messages to (group or user)
FEISHU_CHAT_ID=your_feishu_chat_id_here
