# Example .env file for LLM client configuration
# Copy .env.example to .env and fill in your actual API keys

# Select provider: deepseek, qwen, glm, or kimi (default: deepseek)
LLM_PROVIDER=deepseek

# API Keys for each provider (only the selected provider's key is required)
# Get your API keys from:
# - DeepSeek: https://platform.deepseek.com/api_keys
# - Qwen: https://dashscope.console.aliyun.com/apiKey
# - Kimi: https://platform.moonshot.cn/console/api-keys
# - GLM: https://open.bigmodel.cn/usercenter/apikeys
DEEPSEEK_API_KEY=your_actual_deepseek_api_key_here
QWEN_API_KEY=your_actual_qwen_api_key_here
KIMI_API_KEY=your_actual_kimi_api_key_here
GLM_API_KEY=your_actual_glm_api_key_here
